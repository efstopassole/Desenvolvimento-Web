<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CADASTRO TESTE</title>
    <style>
        body { font-family: sans-serif; padding: 20px; }
        form { max-width: 500px; }
        div { margin-bottom: 15px; }
        label { display: block; margin-bottom: 5px; }
    </style>
</head>
<body>

    <h1>CADASTRO TESTE</h1>

    <form action="#" method="POST">
        <fieldset>
            <legend>Crie sua Conta</legend>

            <div>
                <label for="nome">Nome:</label>
                <input type="text" id="nome" name="nome">
            </div>

            <div>
                <label for="email">E-mail:</label>
                <input type="email" id="email" name="email" placeholder="seuemail@dominio.com" required>
            </div>

            <div>
                <label for="senha">Senha (mínimo 8 caracteres e 1 caracter especial):</label>
                <input 
                    type="password" 
                    id="senha" 
                    name="senha" 
                    minlength="8" 
                    pattern="^(?=.*[!@#$%^&*]).{8,}$"
                    title="A senha deve ter no mínimo 8 caracteres e pelo menos um caractere especial (ex: ! @ # $ % & *)"
                    required
                >
            </div>

            <div>
                <strong>Gênero:</strong><br><br>
                <input type="radio" id="fem" name="genero" value="feminino">
                <label style="display:inline" for="fem">Feminino</label><br>
                
                <input type="radio" id="masc" name="genero" value="masculino">
                <label style="display:inline" for="masc">Masculino</label><br>
                
                <input type="radio" id="outro" name="genero" value="outro">
                <label style="display:inline" for="outro">Outro</label>
            </div>

            <div>
                <label for="bio">Biografia:</label>
                <textarea id="bio" name="biografia" rows="5" cols="30" placeholder="Fale um pouco sobre você..."></textarea>
            </div>

            <div>
                <input type="checkbox" id="termos" name="termos" required>
                <label style="display:inline" for="termos">Eu li e aceito os termos de serviço.</label>
            </div>

            <button type="submit">Cadastrar</button>
            <button type="reset">Limpar</button>

        </fieldset>
    </form>

</body>
</html>